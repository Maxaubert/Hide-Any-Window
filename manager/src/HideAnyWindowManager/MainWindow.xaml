<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="HideAnyWindowManager.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:HideAnyWindowManager.ViewModels"
    Title="Hide Any Window">
    <Grid x:Name="RootGrid" Padding="0" Background="{ThemeResource WindowBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Custom title bar (drag region; Windows draws Min/Max/Close on top right) -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Background="Transparent" Padding="14,0,140,0">
            <TextBlock Text="Hide Any Window" VerticalAlignment="Center" FontSize="12" Opacity="0.85"/>
        </Grid>

        <!-- Toolbar -->
        <Grid Padding="20,12,20,10" Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Monitored apps" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/>
            <Button x:Name="SettingsButton" Grid.Column="1" Background="Transparent" BorderThickness="0" Padding="8"
                    Margin="0,0,8,0" Click="SettingsButton_Click" ToolTipService.ToolTip="Settings">
                <FontIcon Glyph="&#xE713;" FontSize="16"/>
            </Button>
            <Button x:Name="AddButton" Grid.Column="2" Content="+ Add" Style="{StaticResource AccentButtonStyle}" Click="AddButton_Click"/>
        </Grid>

        <!-- Rule list -->
        <ListView x:Name="RulesList" Grid.Row="2" Padding="12,4,12,16" SelectionMode="Single"
                  SelectionChanged="RulesList_SelectionChanged">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:RuleViewModel">
                    <Grid Padding="6,8" ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid Width="28" Height="28">
                            <Border CornerRadius="6" Background="#4F7CFF" Visibility="{x:Bind PlaceholderVisibility, Mode=OneWay}">
                                <TextBlock Text="{x:Bind Initial}" Foreground="White" HorizontalAlignment="Center"
                                           VerticalAlignment="Center" FontWeight="SemiBold"/>
                            </Border>
                            <Image Source="{x:Bind Icon, Mode=OneWay}" Visibility="{x:Bind IconVisibility, Mode=OneWay}"/>
                        </Grid>
                        <TextBlock Grid.Column="1" Text="{x:Bind Name}" VerticalAlignment="Center" FontSize="14"/>
                        <ToggleSwitch Grid.Column="2" IsOn="{x:Bind Enabled, Mode=TwoWay}"
                                      IsEnabled="{Binding DataContext.IsServiceRunning, ElementName=RootGrid, Mode=OneWay}"
                                      OnContent="" OffContent="" MinWidth="0" Toggled="RuleToggle_Toggled"/>
                        <Button Grid.Column="3" Click="DeleteRowButton_Click" Padding="6,2" Background="Transparent" BorderThickness="0"
                                ToolTipService.ToolTip="Remove">
                            <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                        </Button>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Footer (service status + Stop/Start) -->
        <Grid Grid.Row="3" Padding="20,12,20,14" Background="{ThemeResource FooterBackground}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="Gray"/>
                <TextBlock x:Name="StatusLabel" Text="Service stopped" FontWeight="SemiBold"/>
            </StackPanel>
            <Button Grid.Column="1" x:Name="ServiceButton" Content="Start service" Click="ServiceButton_Click"/>
        </Grid>
    </Grid>
</Window>
